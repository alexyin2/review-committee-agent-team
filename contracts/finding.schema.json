{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "finding.schema.json",
  "title": "Review Finding",
  "description": "每顆 review lens 輸出的單一 finding。lens 產出 findings.json = { lens, findings: [Finding] }。",
  "type": "object",
  "required": ["lens", "findings"],
  "properties": {
    "lens": {
      "type": "string",
      "description": "維度名,如 security / privacy / legal / ops"
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "severity", "title", "rationale", "recommendation"],
        "properties": {
          "id": { "type": "string", "description": "穩定 id,如 sec-001" },
          "severity": {
            "type": "string",
            "enum": ["blocker", "high", "medium", "low", "info"],
            "description": "blocker = 足以擋上線,交給 verdict-policy 權衡"
          },
          "title": { "type": "string" },
          "rationale": { "type": "string", "description": "為什麼——對照 rubric 哪一條" },
          "recommendation": { "type": "string", "description": "建議怎麼補" },
          "evidence": {
            "type": "string",
            "description": "提交文件中的依據(引用/位置),沒有就標明缺證據"
          },
          "rubric_ref": { "type": "string", "description": "對應 rubric 的條目 id" }
        }
      }
    }
  }
}
